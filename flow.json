    {
        "id": "c3b6da8657e99b9d",
        "type": "function",
        "z": "eff18884ebcb89e8",
        "name": "function 3",
        "func": "let battery = flow.get(\"battery\") || 0;\nlet charging = flow.get(\"charging\") || false;\n\nlet cmd = msg.payload.toString().trim().toUpperCase();\n\n// Handle input logic\nif (cmd === \"START\") charging = true;\nelse if (cmd === \"STOP\") charging = false;\nelse if (cmd === \"RESET\") { battery = 0; charging = false; }\nelse if (cmd === \"85\") { battery = 85; charging = false; }\nelse if (!isNaN(msg.payload)) battery = Number(msg.payload);\nelse if (cmd === \"TICK\" && charging) battery += 5;\n\n// Safety clamps\nif (battery >= 100) { battery = 100; charging = false; }\nif (battery < 0) battery = 0;\n\n// Determine state strings\nlet ledPayload = \"STOPPED\"; // Default\nlet statusText = \"Not Charging\";\n\nif (battery >= 100) {\n    ledPayload = \"FINISHED\";\n    statusText = \"Fully Charged\";\n} else if (charging) {\n    ledPayload = \"CHARGING\";\n    statusText = \"Charging\";\n}\n\n// Save state\nflow.set(\"battery\", battery);\nflow.set(\"charging\", charging);\n\n// Return output\nreturn [\n    { payload: battery },    // 1. Gauge\n    { payload: statusText }, // 2. Text label\n    { payload: ledPayload }  // 3. LED\n];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 380,
        "wires": [
