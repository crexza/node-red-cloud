        "name": "function 1",
        "func": "let solar = false;\nlet bess = false;\nlet grid = false;\n\n// check which button was pressed\nif (msg.payload === \"SOLAR\") {\n    solar = true;\n} else if (msg.payload === \"BESS\") {\n    bess = true;\n} else if (msg.payload === \"POWER GRID\") {\n    grid = true;\n}\n\n// create 3 outputs (one for each LED)\nreturn [\n    { payload: solar, color: solar ? \"green\" : \"white\" },\n    { payload: bess, color: bess ? \"green\" : \"white\" },\n    { payload: grid, color: grid ? \"green\" : \"white\" }\n];",
